generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  fiatBalance  Decimal  @default(10000.00)
  assetBalance Decimal  @default(1.00)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
}

model Order {
  id           String   @id @default(uuid())
  userId       String
  side         String
  type         String
  price        Decimal
  initialQty   Decimal
  remainingQty Decimal
  status       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])
}

model Trade {
  id           String   @id @default(uuid())
  makerOrderId String
  takerOrderId String
  price        Decimal
  qty          Decimal
  executedAt   DateTime @default(now())
}
