generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  username      String   @unique
  email         String?  @unique
  phone         String?  @unique
  passwordHash  String?
  googleId      String?  @unique
  authProvider  String   @default("local")  // "local" | "google" | "phone"
  fiatBalance   Decimal  @default(10000.00)
  assetBalance  Decimal  @default(1.00)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orders        Order[]
}

model Order {
  id           String   @id @default(uuid())
  userId       String
  side         String
  type         String
  price        Decimal
  initialQty   Decimal
  remainingQty Decimal
  status       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])
  makerTrades  Trade[]  @relation("MakerOrder")
  takerTrades  Trade[]  @relation("TakerOrder")
}

model Trade {
  id           String   @id @default(uuid())
  makerOrderId String
  takerOrderId String
  price        Decimal
  qty          Decimal
  executedAt   DateTime @default(now())
  makerOrder   Order    @relation("MakerOrder", fields: [makerOrderId], references: [id])
  takerOrder   Order    @relation("TakerOrder", fields: [takerOrderId], references: [id])
}
